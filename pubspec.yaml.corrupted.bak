### Create AI Debug Screen:

```dart
// FILE: lib/debug/ai_test_screen.dart

import 'package:flutter/material.dart';
import 'package:http/http.dart' as http;
import 'dart:convert';

class AITestScreen extends StatefulWidget {
  @override
  State<AITestScreen> createState() => _AITestScreenState();
}

class _AITestScreenState extends State<AITestScreen> {
  String _log = '';
  bool _testing = false;
  
  void _addLog(String message) {
    setState(() {
      _log += '\n$message';
    });
    print(message);
  }
  
  Future<void> _testNvidiaAPI() async {
    setState(() {
      _testing = true;
      _log = 'Starting NVIDIA API Test...\n';
    });
    
    try {
      _addLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
      _addLog('🧪 NVIDIA API CONNECTION TEST');
      _addLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
      
      const apiKey = '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';
      const endpoint = 'https://integrate.api.nvidia.com/v1/chat/completions';
      
      _addLog('🔑 API Key: ${apiKey.substring(0, 20)}...');
      _addLog('🌐 Endpoint: $endpoint');
      
      final payload = {
        'model': 'qwen/qwen3.5-122b-a10b',
        'messages': [
          {'role': 'user', 'content': 'Say "Hello MamaBuddy" in one sentence.'}
        ],
        'max_tokens': 50,
        'temperature': 0.7,
        'stream': false,
      };
      
      _addLog('📦 Sending request...');
      
      final response = await http.post(
        Uri.parse(endpoint),
        headers: {
          'Authorization': 'Bearer $apiKey',
          'Content-Type': 'application/json',
          'Accept': 'application/json',
        },
        body: jsonEncode(payload),
      ).timeout(Duration(seconds: 30));
      
      _addLog('📊 Status Code: ${response.statusCode}');
      _addLog('📄 Response Length: ${response.body.length} bytes');
      
      if (response.statusCode == 200) {
        final data = jsonDecode(response.body);
        final content = data['choices'][0]['message']['content'];
        
        _addLog('✅ SUCCESS!');
        _addLog('📝 Response: $content');
        _addLog('━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
        _addLog('🎉 API IS WORKING!');
        
      } else {
        _addLog('❌ FAILED!');
        _addLog('Response: ${response.body}');
      }
      
    } catch (e, stack) {
      _addLog('❌ ERROR: $e');
      _addLog('Stack: ${stack.toString().substring(0, 500)}');
    }
    
    setState(() => _testing = false);
  }
  
  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: Text('AI Debug Test'),
        backgroundColor: Color(0xFFC2185B),
        foregroundColor: Colors.white,
      ),
      body: Column(
        children: [
          Padding(
            padding: EdgeInsets.all(20),
            child: ElevatedButton(
              onPressed: _testing ? null : _testNvidiaAPI,
              style: ElevatedButton.styleFrom(
                backgroundColor: Color(0xFFC2185B),
                foregroundColor: Colors.white,
                minimumSize: Size(double.infinity, 50),
              ),
              child: _testing
                  ? Row(
                      mainAxisAlignment: MainAxisAlignment.center,
                      children: [
                        SizedBox(
                          width: 20,
                          height: 20,
                          child: CircularProgressIndicator(
                            strokeWidth: 2,
                            color: Colors.white,
                          ),
                        ),
                        SizedBox(width: 12),
                        Text('Testing...'),
                      ],
                    )
                  : Text('Run NVIDIA API Test'),
            ),
          ),
          Expanded(
            child: Container(
              margin: EdgeInsets.all(20),
              padding: EdgeInsets.all(16),
              decoration: BoxDecoration(
                color: Colors.black87,
                borderRadius: BorderRadius.circular(12),
              ),
              child: SingleChildScrollView(
                child: SelectableText(
                  _log.isEmpty ? 'Tap "Run Test" to start...' : _log,
                  style: TextStyle(
                    fontFamily: 'monospace',
                    fontSize: 12,
                    color: Colors.greenAccent,
                  ),
                ),
              ),
            ),
          ),
        ],
      ),
    );
  }
}
```

